<div class="wrapper">

<!-- ═══════════════════════════════════════════
     UNIT 1
════════════════════════════════════════════ -->
<div class="unit-card" id="unit1">
  <div class="unit-header bg-u1" onclick="toggleUnit(this)">
    <div class="unit-num">01</div>
    <span class="unit-icon">🌿</span>
    <h2>Historical Human–Environment Interactions</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">🌍</span> What is Environment?</h3>
      <p style="font-size:.9rem;color:var(--muted);margin-bottom:12px">Everything around us — living and non-living — that affects life on Earth.</p>
      <div class="compare-row">
        <div class="compare-card" style="background:#eafaf1;border-left:4px solid var(--u1)">
          <h4 style="color:var(--u1)">🌱 Biotic (Living)</h4>
          <ul><li>🌲 Plants</li><li>🐘 Animals</li><li>👤 Humans</li><li>🦠 Microorganisms</li></ul>
        </div>
        <div class="compare-card" style="background:#eaf4fb;border-left:4px solid var(--u2)">
          <h4 style="color:var(--u2)">💎 Abiotic (Non-Living)</h4>
          <ul><li>💨 Air</li><li>💧 Water</li><li>🪨 Soil</li><li>☀️ Sunlight</li></ul>
        </div>
      </div>
      <div class="memory-box" style="background:#eafaf1;border-color:var(--u1)">
        <div class="mb-title text-u1">🧠 Memory Trick</div>
        <div class="mb-content">Environment = Our Earth's Neighborhood 🏘️</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🚶</span> The Human Journey Through Time</h3>
      <div class="flowchart">
        <div class="flow-node bg-u1">🏹 Hunter-Gatherer Stage</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#27ae60">🔥 Discovery of Fire</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#f39c12">🌾 Agricultural Revolution (~10,000 yrs ago)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#e67e22">🏘️ Permanent Settlements</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#8e44ad">🏛️ Civilizations</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#c0392b">🏭 Industrial Revolution</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#2980b9">♻️ Sustainability Era (Today)</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🔥</span> Discovery of Fire – Benefits</h3>
      <div class="info-grid">
        <div class="info-card light-u1"><span class="ic-icon">🍖</span><div class="ic-label">Cooking Food</div><div class="ic-sub">Better nutrition</div></div>
        <div class="info-card light-u1"><span class="ic-icon">🛡️</span><div class="ic-label">Protection</div><div class="ic-sub">Kept predators away</div></div>
        <div class="info-card light-u1"><span class="ic-icon">🌡️</span><div class="ic-label">Warmth</div><div class="ic-sub">Survived cold climates</div></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🌾</span> Agricultural Revolution – Effects on Environment</h3>
      <div class="effect-row">
        <div class="effect-card light-u4"><span class="ec-icon">🌲</span><div class="ec-title text-u4">Deforestation</div><ul><li>Forests cleared for farmland</li><li>Habitat loss began</li></ul></div>
        <div class="effect-card light-u5"><span class="ec-icon">👨‍👩‍👧‍👦</span><div class="ec-title text-u5">Population Boom</div><ul><li>More food = more people</li><li>Villages formed</li></ul></div>
        <div class="effect-card light-u2"><span class="ec-icon">💧</span><div class="ec-title text-u2">Water Use</div><ul><li>Irrigation started</li><li>Rivers diverted</li></ul></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🏭</span> Industrial Revolution – Key Effects</h3>
      <div class="info-grid">
        <div class="info-card light-u4"><span class="ic-icon">🏭</span><div class="ic-label">Factories</div><div class="ic-sub">Mass production</div></div>
        <div class="info-card light-u4"><span class="ic-icon">⛏️</span><div class="ic-label">Coal Mining</div><div class="ic-sub">Fossil fuel era</div></div>
        <div class="info-card light-u4"><span class="ic-icon">💨</span><div class="ic-label">Pollution Spike</div><div class="ic-sub">Air &amp; water polluted</div></div>
        <div class="info-card light-u4"><span class="ic-icon">🚂</span><div class="ic-label">Steam Engines</div><div class="ic-sub">Coal-powered transport</div></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">♻️</span> Sustainability</h3>
      <p style="font-size:.9rem;color:var(--muted);margin-bottom:12px">Using resources wisely today without harming the ability of future generations to meet their needs.</p>
      <div class="formula-box">
        <div style="font-size:.85rem;color:var(--muted);margin-bottom:6px">The Sustainability Formula</div>
        <div class="formula-text">🌱 Development + 🌍 Conservation = ♻️ Sustainability</div>
      </div>
      <div class="info-grid">
        <div class="info-card light-u1"><span class="ic-icon">☀️</span><div class="ic-label">Solar Energy</div><div class="ic-sub">Instead of coal</div></div>
        <div class="info-card light-u1"><span class="ic-icon">🌲</span><div class="ic-label">Afforestation</div><div class="ic-sub">Replanting forests</div></div>
        <div class="info-card light-u1"><span class="ic-icon">🔄</span><div class="ic-label">Recycling</div><div class="ic-sub">Reduce waste</div></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     UNIT 2
════════════════════════════════════════════ -->
<div class="unit-card" id="unit2">
  <div class="unit-header bg-u2" onclick="toggleUnit(this)">
    <div class="unit-num">02</div>
    <span class="unit-icon">💧</span>
    <h2>Natural Resources</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">🗂️</span> Classification Tree</h3>
      <p style="font-size:.9rem;color:var(--muted);margin-bottom:16px">Natural resources = materials from nature useful to humans.</p>
      <div style="overflow-x:auto">
      <div style="display:flex;flex-direction:column;align-items:center;gap:0;min-width:520px">
        <div class="flow-node bg-u2" style="margin-bottom:0">🌍 Natural Resources</div>
        <div style="display:flex;width:340px;justify-content:space-between;height:30px;position:relative">
          <div style="width:1px;background:#3498db;margin-left:84px;height:100%"></div>
          <div style="width:1px;background:#9b59b6;margin-right:84px;height:100%"></div>
          <div style="position:absolute;top:0;left:84px;right:84px;height:1px;background:#bbb"></div>
        </div>
        <div style="display:flex;gap:60px">
          <div style="display:flex;flex-direction:column;align-items:center;gap:8px">
            <div class="flow-node" style="background:var(--u1);min-width:140px">🌱 Biotic (Living)</div>
            <div class="tag-list" style="flex-direction:column;align-items:center">
              <span class="tag" style="background:#27ae60">🌲 Forests</span>
              <span class="tag" style="background:#27ae60">🐾 Animals</span>
              <span class="tag" style="background:#27ae60">🌿 Plants</span>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:center;gap:8px">
            <div class="flow-node" style="background:var(--u3);min-width:140px">💎 Abiotic (Non-Living)</div>
            <div class="tag-list" style="flex-direction:column;align-items:center">
              <span class="tag" style="background:#8e44ad">💧 Water</span>
              <span class="tag" style="background:#8e44ad">💨 Air</span>
              <span class="tag" style="background:#8e44ad">⛏️ Minerals</span>
            </div>
          </div>
        </div>
      </div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">⚡</span> Renewable vs Non-Renewable</h3>
      <div class="compare-row">
        <div class="compare-card" style="background:#eafaf1;border-left:4px solid var(--u1)">
          <h4 style="color:var(--u1)">♻️ Renewable Resources</h4>
          <p style="font-size:.82rem;color:var(--muted);margin-bottom:8px">Naturally replenished — never run out!</p>
          <div class="tag-list"><span class="tag bg-u1">☀️ Solar</span><span class="tag bg-u1">💨 Wind</span><span class="tag bg-u1">💧 Hydro</span><span class="tag bg-u1">🌲 Forests</span></div>
        </div>
        <div class="compare-card" style="background:#fdf2f2;border-left:4px solid var(--u4)">
          <h4 style="color:var(--u4)">⚠️ Non-Renewable Resources</h4>
          <p style="font-size:.82rem;color:var(--muted);margin-bottom:8px">Limited quantity — will run out!</p>
          <div class="tag-list"><span class="tag bg-u4">⛏️ Coal</span><span class="tag bg-u4">🛢️ Petroleum</span><span class="tag bg-u4">🔥 Natural Gas</span></div>
        </div>
      </div>
      <div class="memory-box" style="background:#fff9e6;border-color:var(--u5)">
        <div class="mb-title text-u5">🧠 Memory Trick</div>
        <div class="mb-content">☀️ Sun = Renewable &nbsp;|&nbsp; ⛏️ Coal = Non-Renewable</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🔍</span> Key Resources – Problems &amp; Importance</h3>
      <table class="styled-table">
        <thead><tr><th class="bg-u2">Resource</th><th class="bg-u2">Icon</th><th class="bg-u2">Importance</th><th class="bg-u2">Threats</th></tr></thead>
        <tbody>
          <tr><td><b>Water</b></td><td>💧</td><td>Life, Agriculture, Industry</td><td>Overuse, Pollution, Scarcity</td></tr>
          <tr><td><b>Soil</b></td><td>🪨</td><td>Plant growth, Nutrients, Water storage</td><td>Erosion, Overgrazing, Deforestation</td></tr>
          <tr><td><b>Minerals</b></td><td>⛏️</td><td>Construction, Electronics, Industry</td><td>Habitat loss, Land degradation</td></tr>
          <tr><td><b>Forests</b></td><td>🌲</td><td>Oxygen, Biodiversity, Climate</td><td>Logging, Agriculture expansion</td></tr>
        </tbody>
      </table>
    </div>
    <div class="section">
      <h3><span class="s-icon">⚡</span> Energy Resources</h3>
      <div class="compare-row">
        <div class="compare-card" style="background:#fef5e7;border-left:4px solid var(--u7)">
          <h4 style="color:var(--u7)">🏭 Conventional Energy</h4>
          <div class="tag-list"><span class="tag bg-u7">⛏️ Coal</span><span class="tag bg-u7">🛢️ Petroleum</span><span class="tag bg-u7">🔥 Natural Gas</span></div>
        </div>
        <div class="compare-card" style="background:#eafaf1;border-left:4px solid var(--u1)">
          <h4 style="color:var(--u1)">🌱 Non-Conventional Energy</h4>
          <div class="tag-list"><span class="tag bg-u1">☀️ Solar</span><span class="tag bg-u1">💨 Wind</span><span class="tag bg-u1">🌊 Hydro</span><span class="tag bg-u1">🌿 Biomass</span></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     UNIT 3
════════════════════════════════════════════ -->
<div class="unit-card" id="unit3">
  <div class="unit-header bg-u3" onclick="toggleUnit(this)">
    <div class="unit-num">03</div>
    <span class="unit-icon">🌳</span>
    <h2>Ecosystems and Biodiversity</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">🔄</span> Energy Flow in an Ecosystem</h3>
      <div class="flowchart">
        <div class="flow-node" style="background:#f39c12">☀️ Sun (Energy Source)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node bg-u1">🌿 Producers (Plants)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#3498db">🐰 Primary Consumers (Herbivores)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node bg-u4">🦊 Secondary Consumers (Carnivores)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#8e44ad">🦁 Apex Predators</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#795548">🍄 Decomposers (Fungi &amp; Bacteria)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node bg-u1" style="font-size:.8rem">♻️ Nutrients returned to Soil</div>
      </div>
      <div class="memory-box" style="background:#f5eef8;border-color:var(--u3)">
        <div class="mb-title text-u3">🧠 Food Chain Example</div>
        <div class="mb-content">🌾 Grass → 🐰 Rabbit → 🦊 Fox → 🍄 Decomposer</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🌈</span> Types of Biodiversity</h3>
      <div class="info-grid">
        <div class="info-card light-u3"><span class="ic-icon">🧬</span><div class="ic-label">Genetic Diversity</div><div class="ic-sub">Differences within a species<br>Example: Mango varieties</div></div>
        <div class="info-card light-u3"><span class="ic-icon">🐯</span><div class="ic-label">Species Diversity</div><div class="ic-sub">Different species together<br>Example: Tiger, Deer, Elephant</div></div>
        <div class="info-card light-u3"><span class="ic-icon">🌏</span><div class="ic-label">Ecosystem Diversity</div><div class="ic-sub">Different ecosystems<br>Example: Forest, Desert, Ocean</div></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">💡</span> Why Biodiversity Matters</h3>
      <div class="circular-badges">
        <div class="c-badge bg-u1"><span class="cb-icon">🍎</span>Food &amp; Crops</div>
        <div class="c-badge bg-u2"><span class="cb-icon">💊</span>Medicines</div>
        <div class="c-badge bg-u3"><span class="cb-icon">🐝</span>Pollination</div>
        <div class="c-badge bg-u5"><span class="cb-icon">🌡️</span>Climate Reg.</div>
        <div class="c-badge bg-u6"><span class="cb-icon">⚖️</span>Eco Balance</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🛡️</span> Conservation Strategies</h3>
      <div class="compare-row">
        <div class="compare-card" style="background:#eafaf1;border-left:4px solid var(--u1)">
          <h4 style="color:var(--u1)">🏞️ In-Situ Conservation</h4>
          <p style="font-size:.82rem;color:var(--muted);margin-bottom:8px">Protection IN the natural habitat.</p>
          <ul><li>🏕️ National Parks</li><li>🦁 Wildlife Sanctuaries</li><li>🌿 Biosphere Reserves</li></ul>
        </div>
        <div class="compare-card" style="background:#f5eef8;border-left:4px solid var(--u3)">
          <h4 style="color:var(--u3)">🏛️ Ex-Situ Conservation</h4>
          <p style="font-size:.82rem;color:var(--muted);margin-bottom:8px">Protection OUTSIDE the natural habitat.</p>
          <ul><li>🦓 Zoos &amp; Aquariums</li><li>🌺 Botanical Gardens</li><li>🌱 Seed Banks</li></ul>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     UNIT 4
════════════════════════════════════════════ -->
<div class="unit-card" id="unit4">
  <div class="unit-header bg-u4" onclick="toggleUnit(this)">
    <div class="unit-num">04</div>
    <span class="unit-icon">☁️</span>
    <h2>Pollution and Health</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">🔍</span> Three Major Types of Pollution</h3>
      <div class="effect-row">
        <div class="effect-card" style="background:#fdf2f2;border-color:var(--u4)"><span class="ec-icon">💨</span><div class="ec-title text-u4">Air Pollution</div><ul><li><b>Sources:</b> Vehicles, Factories, Burning fuels</li><li><b>Pollutants:</b> CO₂, SO₂, NOx, Smoke</li><li><b>Effects:</b> Asthma, Lung disease, Global warming</li></ul></div>
        <div class="effect-card" style="background:#eaf4fb;border-color:var(--u2)"><span class="ec-icon">💧</span><div class="ec-title text-u2">Water Pollution</div><ul><li><b>Sources:</b> Sewage, Industrial waste, Oil spills</li><li><b>Effects:</b> Cholera, Typhoid, Aquatic death</li></ul></div>
        <div class="effect-card" style="background:#fef5e7;border-color:var(--u7)"><span class="ec-icon">🪨</span><div class="ec-title text-u7">Soil Pollution</div><ul><li><b>Sources:</b> Pesticides, Plastic, Chemicals</li><li><b>Effects:</b> Reduced fertility, Toxic food</li></ul></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">♻️</span> The 3R Principle</h3>
      <div class="flowchart">
        <div class="flow-node bg-u1">📉 REDUCE — Use less in the first place</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node bg-u2">🔁 REUSE — Use items multiple times</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node bg-u3">♻️ RECYCLE — Convert waste into new products</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🛠️</span> Other Control Measures</h3>
      <div class="info-grid">
        <div class="info-card light-u1"><span class="ic-icon">🔧</span><div class="ic-label">Waste Treatment</div><div class="ic-sub">Before discharge</div></div>
        <div class="info-card light-u2"><span class="ic-icon">🏭</span><div class="ic-label">Pollution Devices</div><div class="ic-sub">Scrubbers, filters</div></div>
        <div class="info-card light-u6"><span class="ic-icon">🌿</span><div class="ic-label">Green Energy</div><div class="ic-sub">Solar, Wind</div></div>
        <div class="info-card light-u5"><span class="ic-icon">📋</span><div class="ic-label">Legislation</div><div class="ic-sub">Environmental laws</div></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     UNIT 5
════════════════════════════════════════════ -->
<div class="unit-card" id="unit5">
  <div class="unit-header bg-u5" onclick="toggleUnit(this)">
    <div class="unit-num">05</div>
    <span class="unit-icon">🌐</span>
    <h2>Environmental Issues and Scales</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">📐</span> Environmental Scales – The Scale Pyramid</h3>
      <div class="pyramid">
        <div class="pyr-level bg-u4" style="width:280px;height:44px">🌍 Planetary Scale — Whole Earth</div>
        <div class="pyr-level" style="background:#e67e22;width:230px;height:44px;margin-top:4px">🌏 Synoptic Scale — Country / Continent</div>
        <div class="pyr-level bg-u5" style="width:180px;height:44px;margin-top:4px">🏙️ Meso Scale — City / Region</div>
        <div class="pyr-level bg-u1" style="width:130px;height:44px;margin-top:4px">🏠 Micro Scale — Home / Farm</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🔍</span> Local vs Global Issues</h3>
      <div class="compare-row">
        <div class="compare-card" style="background:#fff9e6;border-left:4px solid var(--u5)">
          <h4 style="color:var(--u5)">🏙️ Local Issues</h4>
          <ul><li>💧 Water shortage in cities</li><li>🗑️ Garbage accumulation</li><li>🚗 Urban air pollution</li><li>🌊 Local river pollution</li></ul>
        </div>
        <div class="compare-card" style="background:#eaf4fb;border-left:4px solid var(--u2)">
          <h4 style="color:var(--u2)">🌍 Global Issues</h4>
          <ul><li>🌡️ Climate change</li><li>☁️ Ozone layer depletion</li><li>🦋 Biodiversity loss</li><li>🌊 Sea-level rise</li></ul>
        </div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">⚠️</span> Major Environmental Issues</h3>
      <div class="info-grid">
        <div class="info-card light-u4"><span class="ic-icon">👨‍👩‍👧‍👦</span><div class="ic-label">Population Growth</div><div class="ic-sub">More people = More resource demand</div></div>
        <div class="info-card light-u5"><span class="ic-icon">🏙️</span><div class="ic-label">Urbanization</div><div class="ic-sub">Rapid expansion of cities</div></div>
        <div class="info-card light-u7"><span class="ic-icon">🌲</span><div class="ic-label">Deforestation</div><div class="ic-sub">Forests cleared for development</div></div>
        <div class="info-card light-u4"><span class="ic-icon">📉</span><div class="ic-label">Resource Depletion</div><div class="ic-sub">Overuse of natural resources</div></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🎯</span> Sustainable Development Goals (SDGs)</h3>
      <div class="circular-badges">
        <div class="c-badge" style="background:#00aed9"><span class="cb-icon">💧</span>Clean Water</div>
        <div class="c-badge" style="background:#3f7e44"><span class="cb-icon">🌡️</span>Climate Action</div>
        <div class="c-badge" style="background:#fcc30b;color:#333"><span class="cb-icon">⚡</span>Clean Energy</div>
        <div class="c-badge" style="background:#56c02b"><span class="cb-icon">🌿</span>Life on Land</div>
        <div class="c-badge" style="background:#0a97d9"><span class="cb-icon">🐠</span>Life Below Water</div>
        <div class="c-badge" style="background:#fd6925"><span class="cb-icon">🤝</span>Partnerships</div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     UNIT 6
════════════════════════════════════════════ -->
<div class="unit-card" id="unit6">
  <div class="unit-header bg-u6" onclick="toggleUnit(this)">
    <div class="unit-num">06</div>
    <span class="unit-icon">🌡️</span>
    <h2>Climate Change</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">🏡</span> The Greenhouse Effect</h3>
      <div class="flowchart">
        <div class="flow-node" style="background:#f39c12">☀️ Sunlight reaches Earth</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#e67e22">🌍 Earth Surface absorbs heat</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#d35400">🔥 Heat released as infrared radiation</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#c0392b">☁️ Greenhouse gases TRAP the heat</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node bg-u4">🌡️ Earth gets warmer (Greenhouse Effect)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#8e44ad">🌊 Climate Change &amp; Global Warming</div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">☁️</span> Greenhouse Gases</h3>
      <div class="info-grid">
        <div class="info-card light-u4"><span class="ic-icon">🏭</span><div class="ic-label">CO₂</div><div class="ic-sub">Carbon Dioxide – burning fuels</div></div>
        <div class="info-card light-u5"><span class="ic-icon">🐄</span><div class="ic-label">Methane (CH₄)</div><div class="ic-sub">Livestock, rice paddies</div></div>
        <div class="info-card light-u2"><span class="ic-icon">💧</span><div class="ic-label">Water Vapour</div><div class="ic-sub">Most abundant GHG</div></div>
        <div class="info-card light-u6"><span class="ic-icon">🌀</span><div class="ic-label">Ozone (O₃)</div><div class="ic-sub">Lower atmosphere GHG</div></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">⚡</span> Effects of Climate Change</h3>
      <div class="effect-row">
        <div class="effect-card" style="background:#fdf2f2;border-color:var(--u4)"><span class="ec-icon">🌍</span><div class="ec-title text-u4">Environmental Effects</div><ul><li>🌡️ Rising temperatures</li><li>🧊 Melting glaciers</li><li>🌊 Sea-level rise</li><li>🌵 More droughts</li><li>🌧️ Intense floods</li></ul></div>
        <div class="effect-card" style="background:#fef5e7;border-color:var(--u7)"><span class="ec-icon">👤</span><div class="ec-title text-u7">Human Effects</div><ul><li>🌾 Food insecurity</li><li>💧 Water shortages</li><li>🤒 Health problems</li><li>🏚️ Displacement</li></ul></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🛡️</span> Mitigation vs Adaptation</h3>
      <div class="compare-row">
        <div class="compare-card" style="background:#eafaf1;border-left:4px solid var(--u1)">
          <h4 style="color:var(--u1)">🔧 Mitigation — Reduce the Cause</h4>
          <div class="tag-list"><span class="tag bg-u1">☀️ Solar Energy</span><span class="tag bg-u1">💨 Wind Energy</span><span class="tag bg-u1">🌲 Afforestation</span></div>
        </div>
        <div class="compare-card" style="background:#eaf4fb;border-left:4px solid var(--u2)">
          <h4 style="color:var(--u2)">🔄 Adaptation — Adjust to the Impact</h4>
          <div class="tag-list"><span class="tag bg-u2">🌊 Seawalls</span><span class="tag bg-u2">🌾 Drought Crops</span><span class="tag bg-u2">⚠️ Disaster Planning</span></div>
        </div>
      </div>
      <div class="memory-box" style="background:#e8f8f5;border-color:var(--u6)">
        <div class="mb-title text-u6">🧠 Easy Trick</div>
        <div class="mb-content">Mitigation = FIX the problem 🔧 &nbsp;|&nbsp; Adaptation = LIVE with the problem 🧘</div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     UNIT 7
════════════════════════════════════════════ -->
<div class="unit-card" id="unit7">
  <div class="unit-header bg-u7" onclick="toggleUnit(this)">
    <div class="unit-num">07</div>
    <span class="unit-icon">⚙️</span>
    <h2>Environmental Management</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">📋</span> Environmental Impact Assessment (EIA)</h3>
      <p style="font-size:.9rem;color:var(--muted);margin-bottom:14px">A study conducted <b>before</b> starting any major project to identify environmental impacts.</p>
      <div class="flowchart">
        <div class="flow-node" style="background:#3498db">📝 Project Proposal</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#1abc9c">🔬 Environmental Study (Scoping)</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#f39c12">📊 Impact Analysis</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#9b59b6">📣 Public Consultation</div>
        <div class="flow-arrow">↓</div>
        <div class="flow-node" style="background:#e67e22">📄 EIA Report</div>
        <div class="flow-arrow">↓</div>
        <div style="display:flex;gap:20px">
          <div class="flow-node bg-u1">✅ Approval</div>
          <div class="flow-node bg-u4">❌ Rejection</div>
        </div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">⚖️</span> Key Environmental Principles</h3>
      <div class="effect-row">
        <div class="effect-card" style="background:#fdf2f2;border-color:var(--u4)"><span class="ec-icon">💰</span><div class="ec-title text-u4">Polluter Pays Principle</div><ul><li>Polluters bear cleanup costs</li><li>Example: Factory pays to clean polluted river</li></ul></div>
        <div class="effect-card" style="background:#eafaf1;border-color:var(--u1)"><span class="ec-icon">🤝</span><div class="ec-title text-u1">Community Participation</div><ul><li>🌳 Tree plantation drives</li><li>♻️ Recycling campaigns</li><li>📢 Awareness programs</li></ul></div>
        <div class="effect-card" style="background:#eaf4fb;border-color:var(--u2)"><span class="ec-icon">🔮</span><div class="ec-title text-u2">Precautionary Principle</div><ul><li>Act before damage occurs</li><li>Prevention is better than cure</li></ul></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════
     UNIT 8
════════════════════════════════════════════ -->
<div class="unit-card" id="unit8">
  <div class="unit-header bg-u8" onclick="toggleUnit(this)">
    <div class="unit-num">08</div>
    <span class="unit-icon">📜</span>
    <h2>International Treaties and Legislation</h2>
    <button class="toggle-btn">▼</button>
  </div>
  <div class="unit-body">
    <div class="section">
      <h3><span class="s-icon">📅</span> International Treaties Timeline</h3>
      <div class="timeline">
        <div class="tl-item"><div class="tl-dot bg-u3">71</div><div class="tl-year text-u3">1971</div><div class="tl-content border-u3"><h4>🌊 Ramsar Convention</h4><p>Protection of wetlands — lakes, marshes, and river deltas.</p></div></div>
        <div class="tl-item"><div class="tl-dot bg-u1">73</div><div class="tl-year text-u1">1973</div><div class="tl-content border-u1"><h4>🦁 CITES</h4><p>Convention on International Trade in Endangered Species — prevents illegal wildlife trade.</p></div></div>
        <div class="tl-item"><div class="tl-dot bg-u7">87</div><div class="tl-year text-u7">1987</div><div class="tl-content border-u7"><h4>🌀 Montreal Protocol</h4><p>Phase out CFCs to protect the ozone layer. ✅ Most successful treaty!</p></div></div>
        <div class="tl-item"><div class="tl-dot bg-u1">92</div><div class="tl-year text-u1">1992</div><div class="tl-content border-u1"><h4>🌿 Convention on Biological Diversity (CBD)</h4><p>Protect biodiversity — conservation and sustainable use of life on Earth.</p></div></div>
        <div class="tl-item"><div class="tl-dot bg-u4">97</div><div class="tl-year text-u4">1997</div><div class="tl-content border-u4"><h4>🏭 Kyoto Protocol</h4><p>Developed nations commit to reducing greenhouse gas emissions.</p></div></div>
        <div class="tl-item"><div class="tl-dot bg-u6">15</div><div class="tl-year text-u6">2015</div><div class="tl-content border-u6"><h4>🌍 Paris Agreement</h4><p>Limit global warming to below 2°C. All nations participate. Landmark agreement!</p></div></div>
      </div>
    </div>
    <div class="section">
      <h3><span class="s-icon">🧠</span> Memory Table – Treaties at a Glance</h3>
      <table class="styled-table">
        <thead><tr><th class="bg-u8">Treaty</th><th class="bg-u8">Year</th><th class="bg-u8">Purpose</th><th class="bg-u8">Memory Hook</th></tr></thead>
        <tbody>
          <tr><td><b>🌊 Ramsar</b></td><td>1971</td><td>Wetland protection</td><td>🌊 Ramsar = Wetlands</td></tr>
          <tr><td><b>🦁 CITES</b></td><td>1973</td><td>Stop wildlife trade</td><td>🦁 CITES = Save Animals</td></tr>
          <tr><td><b>🌀 Montreal</b></td><td>1987</td><td>Protect ozone layer</td><td>🌀 Montreal = Ozone</td></tr>
          <tr><td><b>🌿 CBD</b></td><td>1992</td><td>Biodiversity</td><td>🌿 CBD = Save Species</td></tr>
          <tr><td><b>🏭 Kyoto</b></td><td>1997</td><td>Reduce GHG</td><td>🏭 Kyoto = Cut Emissions</td></tr>
          <tr><td><b>🌍 Paris</b></td><td>2015</td><td>Limit warming 2°C</td><td>🌍 Paris = Climate Action</td></tr>
        </tbody>
      </table>
    </div>
    <div class="section">
      <h3><span class="s-icon">🇮🇳</span> Environmental Laws in India</h3>
      <div class="info-grid">
        <div class="info-card light-u8"><span class="ic-icon">📗</span><div class="ic-label">Wildlife Protection Act</div><div class="ic-sub">1972 – Protects animals &amp; plants</div></div>
        <div class="info-card light-u8"><span class="ic-icon">💧</span><div class="ic-label">Water Act</div><div class="ic-sub">1974 – Prevents water pollution</div></div>
        <div class="info-card light-u8"><span class="ic-icon">💨</span><div class="ic-label">Air Act</div><div class="ic-sub">1981 – Controls air pollution</div></div>
        <div class="info-card light-u8"><span class="ic-icon">🌍</span><div class="ic-label">Environment Protection Act</div><div class="ic-sub">1986 – Umbrella legislation</div></div>
      </div>
    </div>
  </div>
</div>

